# ─────────────────────────────────────────────────────────────────
# .env.example  —  Copy to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────────

# AWS credentials (use IAM role on SageMaker/EC2; keys only for local dev)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# S3 bucket for model artifacts and data
S3_BUCKET=clinical-ai-demo-bucket

# SageMaker execution role ARN
SAGEMAKER_ROLE=arn:aws:iam::ACCOUNT_ID:role/SageMakerExecutionRole

# AWS Bedrock (for report generation)
# Enable Claude 3 Haiku access in AWS Bedrock console → Model access
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# HuggingFace token (needed to download BiomedCLIP from HF Hub)
HUGGINGFACE_TOKEN=hf_your_token_here

# PhysioNet credentials (for MIMIC-CXR download)
PHYSIONET_USERNAME=your_username
PHYSIONET_PASSWORD=your_password
